# ===== 应用配置 =====
DEBUG=true
SECRET_KEY=change-me-in-production

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./app.db
# 生产环境示例：postgresql+asyncpg://user:pass@localhost:5432/dbname
# 注意：密码特殊字符需 URL 编码（@ → %40, : → %3A, # → %23）

# ===== 服务器 =====
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]

# ===== 认证（如需要）=====
# JWT_SECRET_KEY=change-me
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080

# ===== AI（如需要）=====
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
